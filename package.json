{
  "name": "@trubnikov/physics-engine",
  "version": "1.0.0",
  "description": "A generative design system based on physical laws, not static values. Every dimension, color, and motion is derived — never hardcoded.",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "physics-engine": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "lint:design": "node dist/cli.js lint DESIGN.md",
    "export:tailwind": "node dist/cli.js export --format tailwind DESIGN.md",
    "export:dtcg": "node dist/cli.js export --format dtcg DESIGN.md",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": "./dist/design-physics-engine.js",
    "./linter": "./dist/lint.js",
    "./exporter": "./dist/export.js",
    "./parser": "./dist/parse.js"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "ai",
    "physics",
    "ui",
    "tokens",
    "tailwind",
    "swiftui",
    "framer-motion",
    "design.md",
    "wcag",
    "generative",
    "typography",
    "accessibility"
  ],
  "author": {
    "name": "Dima Trubnikov",
    "url": "https://github.com/trubnikov"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trubnikov/design-physics-engine.git"
  },
  "homepage": "https://github.com/trubnikov/design-physics-engine#readme",
  "bugs": {
    "url": "https://github.com/trubnikov/design-physics-engine/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.9.3"
  }
}
